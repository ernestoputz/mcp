# Copy this file to .env and fill in your values.
# .env is listed in .gitignore — never commit secrets.

# ── Prometheus ────────────────────────────────────────────────────────────────
PROMETHEUS_URL=http://prometheus:9090

# Basic auth (optional — use one auth method only)
# PROMETHEUS_USERNAME=
# PROMETHEUS_PASSWORD=

# Bearer token auth (optional)
# PROMETHEUS_BEARER_TOKEN=

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_URL=http://grafana:3000

# Service account token (recommended — create under Grafana > Administration > Service Accounts)
GRAFANA_API_KEY=glsa_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Basic auth fallback (if not using API key)
# GRAFANA_USERNAME=admin
# GRAFANA_PASSWORD=

GRAFANA_ORG_ID=1

# ── MCP Server auth ───────────────────────────────────────────────────────────
# If set, clients must send: Authorization: Bearer <token>
# Generate with: openssl rand -hex 32
MCP_AUTH_TOKEN=

# ── Server ────────────────────────────────────────────────────────────────────
HTTP_PORT=8080
HTTP_HOST=0.0.0.0
LOG_LEVEL=info

# ── HTTPS (optional) ──────────────────────────────────────────────────────────
# Set both to enable TLS. Paths are inside the container — the docker-compose
# file mounts ./certs to /certs by default. Generate a self-signed cert with:
#   mkdir -p certs && openssl req -x509 -newkey rsa:2048 -nodes -days 365 \
#     -keyout certs/server.key -out certs/server.crt -subj "/CN=localhost"
# TLS_CERT_FILE=/certs/server.crt
# TLS_KEY_FILE=/certs/server.key

# ── OAuth 2.0 (optional, required by claude.ai for remote MCP servers) ───────
# When OAUTH_CLIENT_ID is set, OAuth replaces MCP_AUTH_TOKEN. The flow is
# Authorization Code + PKCE (RFC 7636); access tokens are stateless JWTs (HS256).
# Generate each value below with:  openssl rand -hex 32
# OAUTH_ISSUER must be the public URL clients reach this server at, INCLUDING
# the port if it is non-standard. Example for Caddy mode on :8443:
#   OAUTH_ISSUER=https://mcp.example.com:8443
# Mismatch (e.g. omitting the port) will silently break discovery + JWT iss.
# OAUTH_ISSUER=https://your-public-mcp-url
# OAUTH_CLIENT_ID=
# OAUTH_CLIENT_SECRET=
# OAUTH_SIGNING_KEY=
# Optional TTL overrides (Go duration syntax: "1h", "15m", "30s"). Defaults: 1h / 720h / 60s.
# OAUTH_ACCESS_TTL=1h
# OAUTH_REFRESH_TTL=720h
# OAUTH_CODE_TTL=60s
# Set to "true" only if you knowingly want OAuth over plain http:// (development).
# OAUTH_ALLOW_INSECURE=false
# Rate limiting tunables. Increase TOKEN/AUTHORIZE rates if you have many users
# behind a single proxy IP. Defaults: 5/min /token, 30/min /authorize,
# 10 consecutive failures → 10min hard block.
# OAUTH_TOKEN_RATE_PER_MINUTE=5
# OAUTH_AUTHORIZE_RATE_PER_MINUTE=30
# OAUTH_FAIL_LIMIT=10
# OAUTH_FAIL_BLOCK_DURATION=10m
# Comma-separated IPs/CIDRs whose X-Forwarded-For will be trusted for rate
# limiting. Private RFC1918 ranges are trusted automatically — set this only
# for unusual topologies (e.g. proxy on a public IP).
# OAUTH_TRUSTED_PROXIES=

# ── Caddy + Let's Encrypt via Route 53 (only used by `make up-caddy`) ────────
# Brings up a Caddy reverse proxy that auto-issues and renews a real Let's
# Encrypt certificate using the DNS-01 challenge (no port 80 required).
# The IAM user behind these credentials must be allowed to ChangeResourceRecordSets
# on the hosted zone of CADDY_DOMAIN — see README "Caddy + Let's Encrypt".
# CADDY_DOMAIN=mcpobservability.example.com
# CADDY_EMAIL=you@example.com
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
