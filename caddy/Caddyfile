# Reverse proxy that terminates TLS for the MCP server.
# Certificates come from Let's Encrypt via the ACME DNS-01 challenge,
# so port 80 is not required to be reachable.

{
	email {$CADDY_EMAIL}
}

{$CADDY_DOMAIN}:8443 {
	tls {
		dns route53
		# Wait for the TXT record to propagate before asking Let's Encrypt to
		# validate. Route 53 propagates fast, but LE queries from multiple
		# resolvers and a stale negative cache can produce false NXDOMAIN.
		propagation_delay 60s
		propagation_timeout 5m
	}
	log {
		output stderr
		format json
	}
	reverse_proxy mcp-observability:8080
}
